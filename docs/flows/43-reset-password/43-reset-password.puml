@startuml 43-reset-password
!theme plain
skinparam sequenceMessageAlign center

title Reset Password

actor User
participant "ForgotPasswordPage\n(Angular)" as SPA1
participant "ResetPasswordPage\n(Angular)" as SPA2
participant "Rate limiter" as RL
participant "POST /api/auth/forgot-password" as API1
participant "POST /api/auth/reset-password" as API2
participant "EmailService" as EMAIL
participant "Argon2Hasher" as H
participant "AppDbContext" as CTX
database "users" as DB
database "password_resets" as PR
database "refresh_tokens" as RT

== Request Reset ==
User -> SPA1: enter email, submit
SPA1 -> RL: POST /api/auth/forgot-password\n{email}
RL -> RL: check per-email bucket\n<=3 per hour
alt under limit
    RL -> API1: forward
    API1 -> CTX: Users.FirstOrDefault(Email=@e)
    CTX -> DB: SELECT
    DB --> CTX: user row | null
    CTX --> API1: row
    alt user exists
        API1 -> API1: generate reset token\n(32 bytes, base64)
        API1 -> API1: tokenHash = SHA256(token)
        API1 -> CTX: PasswordResets.Add(userId, tokenHash,\nexpiresAt: +24h, used: false)
        CTX -> PR: INSERT
        PR --> CTX: success
        CTX --> API1: success
        API1 -> EMAIL: send email with\nreset link (token)
        EMAIL --> API1: sent
    end
    API1 --> SPA1: 200 "Check your email"
    SPA1 --> User: show cooldown timer
else over limit
    RL --> SPA1: 429 Too Many Requests\nRetry-After
    SPA1 --> User: "Too many requests"
end

== Perform Reset ==
User -> SPA2: click email link\n(token in URL)
SPA2 -> API2: POST /api/auth/reset-password\n{email, token, newPassword}
API2 -> API2: tokenHash = SHA256(token)
API2 -> CTX: PasswordResets.FirstOrDefault(email, tokenHash)
CTX -> PR: SELECT
PR --> CTX: reset record | null
CTX --> API2: record
alt token valid and not expired\nand not used
    API2 -> API2: validate password complexity
    alt password OK
        API2 -> H: Hash(newPassword)
        H --> API2: passwordHash
        API2 -> CTX: Users.Update(email, passwordHash)
        CTX -> DB: UPDATE
        DB --> CTX: success
        API2 -> CTX: PasswordResets.Update(used=true)
        CTX -> PR: UPDATE
        PR --> CTX: success
        API2 -> CTX: RefreshTokens.DeleteWhere(userId)
        CTX -> RT: DELETE
        RT --> CTX: success
        API2 -> EMAIL: send confirmation email
        EMAIL --> API2: sent
        API2 --> SPA2: 200 "Password reset"
        SPA2 --> User: navigate /login\n"Reset successful"
    else password invalid
        API2 --> SPA2: 400 "Insufficient complexity"
        SPA2 --> User: show requirements
    end
else token expired or invalid\nor already used
    API2 --> SPA2: 400 "Link expired"
    SPA2 --> User: "Link is no longer valid"
end

@enduml
